rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    // Staff login always has a document in users/{uid}.
    // Anonymous auth (chat.html, supplier-view.html) never does.
    function isStaffAuth() { return isAuth() && exists(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function role() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }
    function isOwner() { return isStaffAuth() && role() == 'owner'; }
    function isOwnerOrCS() { return isStaffAuth() && role() in ['owner','cs']; }
    function isData() { return isStaffAuth() && role() == 'data'; }
    function isDivisiOwner() { return isStaffAuth() && role() == 'divisi'; }
    function userDivisi() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.divisi; }
    function isDivisiOwnerOf(div) { return isDivisiOwner() && userDivisi() == div; }

    match /users/{uid} {
      allow read: if isStaffAuth();
      // Self-write allowed for any authenticated user so the anonymous UID doc
      // can be bootstrapped on first session (breaks the circular dependency
      // where isStaffAuth requires the doc to exist before it can be created).
      allow write: if isOwner() || (isAuth() && request.auth.uid == uid);
    }
    match /orders/{orderId} {
      allow read: if isAuth();   // isAuth() (not isStaffAuth) — supplier-view.html uses anonymous auth
      allow create: if isStaffAuth();
      allow update: if isAuth();
      allow delete: if isOwner();
    }
    match /orders/{orderId}/progress_updates/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isStaffAuth(); // edit progress (note/percentage)
      allow delete: if isOwner() || isStaffAuth(); // manager/cs/divisi bisa hapus
    }
    match /orders/{orderId}/internal_chat/{msgId} {
      allow read: if isStaffAuth();
      allow create: if isStaffAuth();
      allow delete: if isOwner();
    }
    match /orders/{orderId}/supplier_chat/{msgId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }
    // Per-supplier chat (order baru dengan 1+ supplier terpisah)
    match /orders/{orderId}/supplier_chats/{supplierId}/messages/{msgId} {
      allow read: if isAuth();   // supplier akses via anonymous auth + token
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }
    match /product_knowledge/{id} {
      allow read: if true; // Public — customer can read
      allow write: if isOwner() || isData() || isDivisiOwnerOf(id);
    }
    match /order_counters/{div} {
      allow read, write: if isStaffAuth();
    }
    match /price_list/{div} {
      allow read: if isAuth(); // Customers can see priceNormal — chat.html strips priceModal/pricePromo/priceAdmin
      allow write: if isOwnerOrCS() || isData() || isDivisiOwnerOf(div);
    }
    match /settings/{id} {
      allow read: if isStaffAuth();
      allow write: if isStaffAuth();
    }

    // Public order info for customer chat (token-based access)
    match /public_order_info/{chatToken} {
      allow read: if true;
      allow write: if isStaffAuth();
    }

    match /lokasi/{id} {
      allow read: if isStaffAuth();
      allow write: if isOwner();
    }

    match /divisions/{id} {
      allow read: if isAuth(); // Public read so chat.html can filter inactive divisions
      allow write: if isOwner();
    }

    match /suppliers/{id} {
      allow read: if isStaffAuth();
      allow write: if isOwner();
    }

    match /supplier_tokens/{token} {
      allow read: if true; // Supplier akses via token tanpa login
      allow write: if isStaffAuth();
    }

    // Chat messages — public read/write (token = password)
    match /chat_messages/{chatToken}/messages/{msgId} {
      allow read: if true;
      allow create: if true; // Anyone with token can send
      allow delete: if isOwner();
    }

    // Chat inbox threads — readable by all staff, writable by owner/cs
    match /chat_threads/{threadId} {
      allow read: if isStaffAuth();
      allow write: if isOwnerOrCS();
    }
    match /chat_threads/{threadId}/messages/{msgId} {
      allow read: if isStaffAuth();
      allow create: if isStaffAuth();
      allow delete: if isOwner();
    }

    // WA number mapping — HANYA backend (Cloudflare Worker) yang boleh akses
    // Firestore Rules memblokir semua client — Worker pakai service account yang bypass rules
    match /chat_wa_numbers/{waNumber} {
      allow read, write: if false;
    }

    // Chat thread counter — backend only
    match /chat_counters/{id} {
      allow read, write: if false;
    }

    // In-app notifications per order internal chat
    match /notifications/{notifId} {
      allow read: if isStaffAuth();
      allow create: if isStaffAuth();
      allow delete: if isOwner();
    }

    // Konsultasi pra-order (sebelum ada order) — dibuat oleh WA Bot via service account
    match /consultations/{token} {
      allow read: if true;   // public — customer akses via token
      allow write: if false; // hanya backend (service account bypass rules)
    }

    // Flag pesan mencurigakan — staff menulis, owner yang baca & tinjau
    match /chat_flags/{id} {
      allow read: if isOwner();
      allow create: if isStaffAuth();
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    // Bot session state per WA number — hanya Worker (service account bypass rules)
    match /chat_sessions/{waNumber} {
      allow read, write: if false;
    }

    // Customer feedback — public write (token = password), staff read only
    match /feedback/{token} {
      allow read: if isStaffAuth();
      allow create: if true; // Anyone with token can submit feedback
      allow update: if false; // No editing after submit
      allow delete: if isOwner();
    }
  }
}
