rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function role() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }
    function isOwner() { return isAuth() && role() == 'owner'; }
    function isOwnerOrCS() { return isAuth() && role() in ['owner','cs']; }
    function isData() { return isAuth() && role() == 'data'; }

    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isOwner() || request.auth.uid == uid;
    }
    match /orders/{orderId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['unreadCustomerChat']);
      allow delete: if isOwner();
    }
    match /orders/{orderId}/progress_updates/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isOwner();
    }
    match /orders/{orderId}/internal_chat/{msgId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isOwner();
    }
    match /product_knowledge/{id} {
      allow read: if true; // Public — customer can read
      allow write: if isOwnerOrCS();
    }
    match /order_counters/{div} {
      allow read, write: if isAuth();
    }
    match /price_list/{div} {
      allow read: if true; // Public — customer can read (UI filters to Normal only)
      allow write: if isOwnerOrCS() || isData();
    }
    match /settings/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // Public order info for customer chat (token-based access)
    match /public_order_info/{chatToken} {
      allow read: if true;
      allow write: if isAuth();
    }

    match /lokasi/{id} {
      allow read: if isAuth();
      allow write: if isOwner();
    }

    match /divisions/{id} {
      allow read: if isAuth();
      allow write: if isOwner();
    }

    // Chat messages — public read/write (token = password)
    match /chat_messages/{chatToken}/messages/{msgId} {
      allow read: if true;
      allow create: if true; // Anyone with token can send
      allow delete: if isOwner();
    }

    // Chat inbox threads — readable by all staff, writable by owner/cs
    match /chat_threads/{threadId} {
      allow read: if isAuth();
      allow write: if isOwnerOrCS();
    }
    match /chat_threads/{threadId}/messages/{msgId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isOwner();
    }

    // WA number mapping — HANYA backend (Cloudflare Worker) yang boleh akses
    // Firestore Rules memblokir semua client — Worker pakai service account yang bypass rules
    match /chat_wa_numbers/{waNumber} {
      allow read, write: if false;
    }

    // Chat thread counter — backend only
    match /chat_counters/{id} {
      allow read, write: if false;
    }

    // In-app notifications per order internal chat
    match /notifications/{notifId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isOwner();
    }

    // @mention badge counter per user
    match /user_mentions/{uid} {
      allow read: if isAuth() && request.auth.uid == uid;
      allow write: if isAuth();
    }
  }
}
