rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Staff (login) bisa akses semua
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    // Customer chat — boleh upload foto tanpa login, max 10MB, hanya gambar & PDF
    match /chats/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType in ['image/jpeg','image/png','image/webp','image/gif','application/pdf'];
    }
  }
}
